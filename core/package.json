{
  "name": "koishi-plugin-yesimbot",
  "version": "4.0.0-beta.3",
  "bugs": {
    "url": "https://github.com/YesWeAreBot/YesImBot/issues"
  },
  "license": "MIT",
  "contributors": [
    "HydroGest <2445691453@qq.com>",
    "Dispure <3116716016@qq.com>",
    "MiaowFISH <miaowfish@qq.com>",
    "Touch-Night <1762918301@qq.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YesWeAreBot/YesImBot.git",
    "directory": "core"
  },
  "files": [
    "dist",
    "resources"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./services/*": {
      "types": "./dist/services/*/index.d.ts",
      "require": "./dist/services/*/index.cjs",
      "import": "./dist/services/*/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc --noEmit && pkgroll --sourcemap --clean-dist",
    "clean": "rimraf dist && rimraf .turbo && rimraf tsconfig.tsbuildinfo",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "pub": "yarn npm publish --access public",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@yesimbot/shared-model": "workspace:^",
    "ai": "^6.0.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "jsonrepair": "^3.13.2",
    "p-queue": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "koishi": "^4.18.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "koishi": "^4.18.3"
  },
  "koishi": {
    "description": {
      "zh": "让语言大模型机器人假装群友并和群友聊天！",
      "en": "A Koishi plugin that allows LLM chat in your guild."
    },
    "service": {
      "required": [
        "database"
      ],
      "implements": [
        "yesimbot"
      ]
    }
  }
}
