{
  "name": "koishi-plugin-yesimbot",
  "version": "4.0.0-beta.5",
  "bugs": {
    "url": "https://github.com/YesWeAreBot/YesImBot/issues"
  },
  "license": "MIT",
  "contributors": [
    "HydroGest <2445691453@qq.com>",
    "Dispure <3116716016@qq.com>",
    "MiaowFISH <miaowfish@qq.com>",
    "Touch-Night <1762918301@qq.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YesWeAreBot/YesImBot.git",
    "directory": "core"
  },
  "files": [
    "dist",
    "resources"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "npx pkgroll --sourcemap",
    "clean": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "pub": "yarn npm publish --access public",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && echo 'TypeScript typecheck passed!'"
  },
  "dependencies": {
    "@ai-sdk-tool/parser": "^4.1.19",
    "@ai-sdk/provider-utils": "^4.0.0",
    "@yesimbot/plugin-sdk": "workspace:^",
    "@yesimbot/shared-model": "workspace:^",
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "koishi": "^4.18.11",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "koishi": "^4.18.11"
  },
  "koishi": {
    "description": {
      "zh": "让语言大模型机器人假装群友并和群友聊天！",
      "en": "A Koishi plugin that allows LLM chat in your guild."
    },
    "service": {
      "required": [
        "database"
      ],
      "implements": [
        "yesimbot"
      ]
    }
  }
}
