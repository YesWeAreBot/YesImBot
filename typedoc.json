{
  "entryPointStrategy": "packages",
  "entryPoints": ["packages/core"],
  "packageOptions": {
    "entryPoints": ["src/index.ts"]
  },
  "exclude": ["**/__tests__/**", "**/mocks/**"],
  "plugin": ["typedoc-plugin-markdown", "typedoc-plugin-rename-defaults"],
  "outputs": [
    {
      "name": "markdown",
      "path": "docs/reference"
    }
  ]
}
