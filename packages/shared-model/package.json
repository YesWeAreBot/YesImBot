{
  "name": "@yesimbot/shared-model",
  "version": "0.1.0-beta.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc --noEmit && pkgroll",
    "clean": "rimraf dist && rimraf .turbo && rimraf tsconfig.tsbuildinfo",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "pub": "yarn npm publish --access public",
    "typecheck": "tsc --noEmit && echo 'Type check passed!'"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "koishi": "^4.18.11"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "koishi": "^4.18.11"
  }
}
