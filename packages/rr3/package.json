{
  "name": "@yesimbot/koishi-plugin-rr3",
  "description": "Yes! I'm Bot! 图片生成 (RR3) 扩展插件",
  "version": "1.0.0",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "homepage": "https://github.com/YesWeAreBot/YesImBot",
  "files": [
    "lib",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node esbuild.config.mjs",
    "dev": "tsc -w --preserveWatchOutput",
    "lint": "eslint . --ext .ts",
