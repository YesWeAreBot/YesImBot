    "pack": "bun pm pack"
  },
  "license": "MIT",
  "contributors": [
    "MiaowFISH <miaow233@qq.com>"
  ],
  "keywords": [
    "koishi",
    "plugin",
    "yesimbot",
    "extension"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HydroGest/YesImBot.git",
    "directory": "packages/favor"
  },
  "devDependencies": {
    "koishi": "^4.18.7",
    "koishi-plugin-yesimbot": "^3.0.0-rc.1"
  },
  "peerDependencies": {
    "koishi": "^4.18.7",
    "koishi-plugin-yesimbot": "^3.0.0-rc.1"
  },
  "koishi": {
    "description": {
      "zh": "为 YesImBot 提供图片生成功能",
