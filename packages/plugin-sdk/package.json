{
  "name": "@yesimbot/plugin-sdk",
  "version": "0.1.0-beta.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.mjs",
      "require": "./dist/tools/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc --noEmit && pkgroll --sourcemap --clean-dist",
    "clean": "rimraf dist && rimraf .turbo && rimraf tsconfig.tsbuildinfo",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && echo 'Type check passed!'"
  },
  "devDependencies": {
    "koishi": "^4.18.3",
    "koishi-plugin-yesimbot": "workspace:^",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "koishi": "^4.18.3",
    "koishi-plugin-yesimbot": "workspace:^"
  }
}
