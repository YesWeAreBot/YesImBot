{
  "name": "@yesimbot/plugin-sdk",
  "version": "0.1.0-beta.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "require": "./dist/tools/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pkgroll",
    "clean": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit && echo 'TypeScript typecheck passed!'"
  },
  "dependencies": {
    "@ai-sdk/provider-utils": "^4.0.21"
  },
  "devDependencies": {
    "koishi": "^4.18.3"
  },
  "peerDependencies": {
    "koishi": "^4.18.3",
    "zod": "^3.25.76 || ^4.1.8"
  }
}
