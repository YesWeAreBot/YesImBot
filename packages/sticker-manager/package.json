{
  "name": "koishi-plugin-yesimbot-extension-sticker-manager",
  "description": "YesImBot 表情包管理扩展",
  "version": "1.0.0",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "scripts": {
    "build": "tsc && node esbuild.config.mjs",
    "dev": "tsc -w --preserveWatchOutput",
