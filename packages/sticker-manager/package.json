  },
  "peerDependencies": {
    "koishi": "^4.18.7",
    "koishi-plugin-yesimbot": "workspace:*"
  },
  "koishi": {
    "description": {
      "zh": "表情包偷取和管理功能",
      "en": "Sticker stealing and management"
    },
    "service": {
      "required": [
        "yesimbot"
      ]
    }
  },
  "dependencies": {
    "sharp": "^0.34.3"
