{{! environment.toon.mustache - 环境模块 (Toon 格式) }}
<environment>
{{! ==================== 频道信息 ==================== }}
+ channel:
  - description: |
      {{#channel.type}}
      {{#_isGroup}}你正在「{{channel.name}}」群聊中。{{/_isGroup}}
      {{#_isPrivate}}你正在和 {{channel.name}} 私聊。{{/_isPrivate}}
      {{/channel.type}}
      {{^channel.type}}
      你正在「{{channel.name}}」中。
      {{/channel.type}}
  - details:
      platform: {{channel.platform}}
      id: {{channel.id}}
      type: {{channel.type}}

{{! ==================== 参与者信息 ==================== }}
{{#participants.length}}
+ participants:
  - description: 以下是当前对话中涉及的人：
{{#participants}}
  - user:
      id: {{id}}
      name: {{name}}
      {{#relationship}}
      relationship:
        {{#intimacy}}intimacy: {{.}}{{/intimacy}}
        {{#notes}}notes: {{.}}{{/notes}}
      {{/relationship}}
      {{#recentImpression}}recent_impression: {{.}}{{/recentImpression}}
{{/participants}}
{{/participants.length}}
</environment>
