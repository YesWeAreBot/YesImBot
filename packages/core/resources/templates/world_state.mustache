{{#triggerContext.length}}
<trigger_context>
  {{#triggerContext}}
  {{#isSystemEvent}}
  <system_alert priority="medium">
    <reason>SYSTEM EVENT DETECTED</reason>
    <instructions>
      A system event occurred in the group, you can respond to it as appropriate.
    </instructions>
    <event_details>
      <type>{{event.eventType}}</type>
      <message>{{event.message}}</message>
    </event_details>
  </system_alert>
  {{/isSystemEvent}}
  {{/triggerContext}}
</trigger_context>
{{/triggerContext.length}}
<world_state>
  <channel id="{{channel.id}}" type="{{channel.type}}" platform="{{channel.platform}}">
    <name>{{channel.name}}</name>
  </channel>
  <users>
  {{#users}}
    <user id="{{id}}">
      <name>{{name}}</name>
      {{#description}}
      <description>{{.}}</description>
      {{/description}}
      {{#roles}}
      <role>{{#.}}{{_toString}}{{/.}}</role>
      {{/roles}}
    </user>
  {{/users}}
  {{^users}}
    <system_note>No user profiles available in the current context.</system_note>
  {{/users}}
  </users>
  {{! ======================= L1 Working Memory ======================= }}
  <working_memory>
    <summary>This is the most recent and active conversation history. It's split into two parts: events that have already been processed, and new, unseen events that triggered this turn.</summary>
    <processed_events>
    {{#l1_working_memory.processed_events}}
      {{#is_message}}
      <message>[{{id}}|{{#timestamp}}{{_formatDate}}{{/timestamp}}|{{sender.name}}({{sender.id}})] {{content}}</message>
      {{/is_message}}
      {{#is_agent_thought}}
      <thoughts>
        <observe>{{observe}}</observe>
        <analyze_infer>{{analyze_infer}}</analyze_infer>
        <plan>{{plan}}</plan>
      </thoughts>
      {{/is_agent_thought}}
      {{#is_agent_action}}
      <action>
        <function>{{function}}</function>
        <params>{{_renderParams}}</params>
      </action>
      {{/is_agent_action}}
      {{#is_agent_observation}}
      <observation>
        <function>{{function}}</function>
        <status>{{status}}</status>
        {{#result}}
        <result>{{#.}}{{_toString}}{{/.}}</result>
        {{/result}}
        {{#error}}
        <error>{{.}}</error>
        {{/error}}
      </observation>
      {{/is_agent_observation}}
      {{#is_system_event}}
      <system_event>[{{#timestamp}}{{_formatDate}}{{/timestamp}}|System] {{message}}</system_event>
      {{/is_system_event}}
    {{/l1_working_memory.processed_events}}
    {{^l1_working_memory.processed_events.length}}
    <system_note>There are no processed events in the current context.</system_note>
    {{/l1_working_memory.processed_events.length}}
    </processed_events>
    <new_events>
    <!-- The following are new events that you have not seen before. -->
    {{#l1_working_memory.new_events}}
      {{#is_message}}
      <message>[{{id}}|{{#timestamp}}{{_formatDate}}{{/timestamp}}|{{sender.name}}({{sender.id}})] {{content}}</message>
      {{/is_message}}
      {{#is_agent_thought}}
      <thoughts>
        <observe>{{observe}}</observe>
        <analyze_infer>{{analyze_infer}}</analyze_infer>
        <plan>{{plan}}</plan>
      </thoughts>
      {{/is_agent_thought}}
      {{#is_agent_action}}
      <action>
        <function>{{function}}</function>
        <params>{{_renderParams}}</params>
      </action>
      {{/is_agent_action}}
      {{#is_agent_observation}}
      <observation>
        <function>{{function}}</function>
        <status>{{status}}</status>
        {{#result}}
        <result>{{#.}}{{_toString}}{{/.}}</result>
        {{/result}}
        {{#error}}
        <error>{{.}}</error>
        {{/error}}
      </observation>
      {{/is_agent_observation}}
      {{#is_system_event}}
      <system_event>[{{#timestamp}}{{_formatDate}}{{/timestamp}}|System] {{message}}</system_event>
      {{/is_system_event}}
    {{/l1_working_memory.new_events}}
    {{^l1_working_memory.new_events.length}}
    <system_note>There are no new events since the last time you responded.</system_note>
    {{/l1_working_memory.new_events.length}}
    </new_events>
  </working_memory>
  {{! ======================= L2 Retrieved Memories ======================= }}
  {{#l2_retrieved_memories}}
  <retrieved_memories>
    <summary>These are relevant snippets from past conversations, retrieved based on semantic similarity to the current topic.</summary>
    {{#.}}
    <memory_chunk relevance="{{relevance}}" timestamp="{{timestamp}}">
      {{content}}
    </memory_chunk>
    {{/.}}
  </retrieved_memories>
  {{/l2_retrieved_memories}}
  {{! ======================= L3 Diary Entries ======================= }}
  {{#l3_diary_entries}}
  <diary_entries>
    <summary>These are my long-term memories, written in the form of diary entries, reflecting on past events.</summary>
    {{#.}}
    <diary_entry date="{{date}}">
      <keywords>
      {{#keywords}}
        <keyword>{{.}}</keyword>
      {{/keywords}}
      </keywords>
      <content>
        {{content}}
      </content>
    </diary_entry>
    {{/.}}
  </diary_entries>
  {{/l3_diary_entries}}
</world_state>