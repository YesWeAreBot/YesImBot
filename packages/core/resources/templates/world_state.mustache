<trigger_context>
  {{#triggerContext}}
  {{#isSystemEvent}}
  <system_alert priority="medium">
    <reason>SYSTEM EVENT DETECTED</reason>
    <instructions>
      A system event occurred in the group, you can respond to it as appropriate.
    </instructions>
    <event_details>
      <type>{{event.eventType}}</type>
      <message>{{event.message}}</message>
    </event_details>
  </system_alert>
  {{/isSystemEvent}}
  {{/triggerContext}}
</trigger_context>

<world_state>
  <channel id="{{channel.id}}" type="{{channel.type}}" platform="{{channel.platform}}">
    <name>{{channel.name}}</name>
  </channel>
  <users>
  {{#users}}
    <user id="{{id}}">
      <name>{{name}}</name>
      <description>{{description}}</description>
    </user>
  {{/users}}
  {{^users}}
    <system_note>No user profiles available in the current context.</system_note>
  {{/users}}
  </users>

  {{! ======================= L1 Working Memory ======================= }}
  <l1_working_memory>
    <summary>This is the most recent and active conversation history.</summary>
    {{#l1_working_memory.processed_turns}}
    <turn id="{{id}}" status="{{status}}" start_time="{{startTimestamp}}" end_time="{{endTimestamp}}">
      <dialogue>
      {{#dialogue}}
        <message id="{{id}}" timestamp="{{timestamp}}" sender_id="{{sender.id}}" sender_name="{{sender.name}}">{{content}}</message>
      {{/dialogue}}
      </dialogue>
      {{#agentTurn}}
      <agent_turn>
        {{#thoughts}}
        <thoughts>
          <observe>{{observe}}</observe>
          <analyze_infer>{{analyze_infer}}</analyze_infer>
          <plan>{{plan}}</plan>
        </thoughts>
        {{/thoughts}}
        {{#actions}}
        <actions>
        {{#.}}
          <action>
            <function>{{function}}</function>
            <params>{{_renderParams}}</params>
          </action>
        {{/.}}
        </actions>
        {{/actions}}
        {{#observations}}
        <observations>
        {{#.}}
          <observation>
            <function>{{function}}</function>
            <status>{{status}}</status>
            <result>{{#result}}{{_toString}}{{/result}}</result>
          </observation>
        {{/.}}
        </observations>
        {{/observations}}
      </agent_turn>
      {{/agentTurn}}
    </turn>
    {{/l1_working_memory.processed_turns}}

    {{#l1_working_memory.pending_turn}}
    <turn id="{{id}}" status="pending" start_time="{{startTimestamp}}">
      <dialogue>
      {{#dialogue}}
        <message id="{{id}}" timestamp="{{timestamp}}" sender_id="{{sender.id}}" sender_name="{{sender.name}}">{{content}}</message>
      {{/dialogue}}
      </dialogue>
    </turn>
    {{/l1_working_memory.pending_turn}}
  </l1_working_memory>

  {{! ======================= L2 Retrieved Memories ======================= }}
  {{#l2_retrieved_memories}}
  <l2_retrieved_memories>
    <summary>These are relevant snippets from past conversations, retrieved based on semantic similarity to the current topic.</summary>
    {{#.}}
    <memory_chunk relevance="{{relevance}}" timestamp="{{timestamp}}">
      {{content}}
    </memory_chunk>
    {{/.}}
  </l2_retrieved_memories>
  {{/l2_retrieved_memories}}

  {{! ======================= L3 Diary Entries ======================= }}
  {{#l3_diary_entries}}
  <l3_diary_entries>
    <summary>These are my long-term memories, written in the form of diary entries, reflecting on past events.</summary>
    {{#.}}
    <diary_entry date="{{date}}">
      <keywords>
      {{#keywords}}
        <keyword>{{.}}</keyword>
      {{/keywords}}
      </keywords>
      <content>
        {{content}}
      </content>
    </diary_entry>
    {{/.}}
  </l3_diary_entries>
  {{/l3_diary_entries}}

</world_state>