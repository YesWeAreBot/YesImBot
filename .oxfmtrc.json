{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [".planning", "docs", "dist"],
  "experimentalSortImports": {
    "order": "asc"
  },
  "experimentalSortPackageJson": {
    "sortScripts": true
  },
  "endOfLine": "lf",
  "semi": true,
  "printWidth": 100,
  "singleQuote": false,
  "insertFinalNewline": true,
  "trailingComma": "all"
}
