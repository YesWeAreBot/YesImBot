{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "lib/**"]
    },
    "clean": {
      "cache": false
    },
    "fmt": {
      "outputs": []
    },
    "fmt:check": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "outputs": []
    },
    "pub": {
      "dependsOn": ["build"],
      "outputs": ["dist/**", "lib/**"]
    },
    "test": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
