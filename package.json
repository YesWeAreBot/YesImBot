{
  "name": "@root/yesimbot",
  "private": true,
  "homepage": "github:HydroGest/YesImBot",
  "license": "MIT",
  "contributors": [
    "HydroGest <2445691453@qq.com>",
    "Dispure <3116716016@qq.com>",
    "MiaowFISH <1293865264@qq.com>",
    "Touch-Night <1762918301@qq.com>"
  ],
  "workspaces": [
    "core",
    "packages/*",
    "plugins/*",
    "providers/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -Apt --topological-dev run build",
    "clean": "yarn workspaces foreach -Ap run clean",
    "fmt": "yarn workspaces foreach -Ap run fmt",
    "fmt:check": "yarn workspaces foreach -Ap run fmt --check",
    "lint": "yarn workspaces foreach -Ap run lint",
    "lint:fix": "yarn workspaces foreach -Ap run lint --fix",
    "prepare": "husky",
    "pub": "yarn build && yarn workspaces foreach -Ap --topological-dev run pub",
    "release": "node scripts/release.mjs",
    "release:beta": "node scripts/release.mjs --beta",
    "test": "yarn workspaces foreach -Ap run test",
    "typecheck": "yarn workspaces foreach -Apt --topological-dev run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.16.2",
    "bumpp": "^10.2.0",
    "husky": "^9.1.7",
    "koishi-plugin-yesimbot-skill": "workspace:^",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "pkgroll": "^2.21.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs,js,jsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.json": [
      "oxfmt --write"
    ]
  },
  "packageManager": "yarn@4.12.0"
}
