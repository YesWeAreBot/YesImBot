{
  "name": "@yesimbot/koishi-plugin-sticker-manager",
  "version": "0.1.0-beta.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc --noEmit && pkgroll --sourcemap --clean-dist",
    "clean": "rimraf dist && rimraf .turbo && rimraf tsconfig.tsbuildinfo",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "pub": "yarn npm publish --access public",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "koishi": "^4.18.10",
    "koishi-plugin-yesimbot": "workspace:^"
  },
  "peerDependencies": {
    "koishi": "^4.18.10",
    "koishi-plugin-yesimbot": "workspace:^"
  },
  "koishi": {
    "description": {
      "zh": "YesImBot v4 表情包偷取与管理插件",
      "en": "Sticker stealing and management plugin for YesImBot v4"
    },
    "service": {
      "required": [
        "database",
        "yesimbot.plugin",
        "yesimbot.model",
        "yesimbot.prompt",
        "yesimbot.image-cache"
      ]
    }
  }
}
