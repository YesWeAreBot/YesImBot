{
  "name": "koishi-plugin-yesimbot-mcp-client",
  "version": "0.1.0-beta.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "npx pkgroll",
    "clean": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "pub": "yarn npm publish --access public",
    "typecheck": "tsc --noEmit && echo 'TypeScript typecheck passed!'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@yesimbot/plugin-sdk": "workspace:^",
    "koishi": "^4.18.10"
  },
  "peerDependencies": {
    "@yesimbot/plugin-sdk": "workspace:^",
    "koishi": "^4.18.10"
  },
  "koishi": {
    "description": {
      "zh": "MCP 协议客户端插件 - 支持 HTTP/SSE/Stdio 传输，自动安装 UV",
      "en": "MCP protocol client plugin - Supports HTTP/SSE/Stdio transport, auto-install UV"
    }
  }
}
